# Copy this file to ".env" (which is git-ignored) and edit as needed.
# NEVER put a real password or any secret in this example file.
# This project does NOT store your Amazon password anywhere — you log in
# manually once (see login.py) and the session is reused.

# Which Amazon regional site to use.
AMAZON_URL=https://www.amazon.com

# Optional default search term used when none is passed on the command line.
SEARCH_QUERY=usb-c cable
